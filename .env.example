# Comma-separated list of ICS calendar feed URLs (read-only)
# Supports any standard ICS feed: Outlook, Google Calendar, Apple, OST, etc.
# Example:
# CALENDAR_URLS=https://calendar.google.com/calendar/ical/.../basic.ics,https://outlook.office365.com/.../calendar.ics
CALENDAR_URLS=

# CalDAV server for read/write access (optional)
# Works with Google Calendar, Nextcloud, iCloud, Fastmail, Radicale, etc.
# Example Google:     https://www.google.com/calendar/dav/YOUR_EMAIL@gmail.com/
# Example Nextcloud:  https://cloud.example.com/remote.php/dav/
# Example iCloud:     https://caldav.icloud.com/
# Example Fastmail:   https://caldav.fastmail.com/
# Example Radicale:   http://localhost:5232/
CALDAV_URL=
CALDAV_USERNAME=
CALDAV_PASSWORD=
